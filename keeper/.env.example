# =============================================================================
# HashPredict Speed Market Keeper — Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# ---------- Keeper Wallet (REQUIRED) ----------
# Must be the SpeedMarketAMM contract owner
# This wallet creates, resolves, and recycles speed markets
KEEPER_PRIVATE_KEY=0x...

# ---------- HashKey Chain Testnet (REQUIRED) ----------
RPC_URL=https://testnet.hsk.xyz
CHAIN_ID=133

# ---------- Contract Addresses (REQUIRED) ----------
SPEED_MARKET_ADDRESS=0x...
COLLATERAL_ADDRESS=0x8065Fec351216Fbd636dc3216884A2eDbBdE1bE2

# ---------- Pyth Price Oracle (REQUIRED) ----------
PYTH_HERMES_URL=https://hermes.pyth.network

# ---------- Speed Market Config (optional, has defaults) ----------
# SLOT_DURATION: Market duration in seconds (default: 900 = 15 minutes)
SLOT_DURATION=900
# INITIAL_LIQUIDITY: USDT seeded per market (6 decimals, default: 100 USDT)
INITIAL_LIQUIDITY=100000000

# ---------- Health Check (optional) ----------
# Port for GET /health endpoint (default: 3001)
HEALTH_PORT=3001
